---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---
<Layout title="Lista de Precios">
  <header class="py-6 mb-4 border-b border-dark-border/50 flex items-center justify-between">
    <div>
      <h1 class="font-['Outfit'] text-2xl font-bold text-orange-400">🏷️ Lista de Precios</h1>
      <p class="text-xs text-text-muted mt-1">Precio efectivo = (costo ingredientes + costo operativo) × markup — Empanadas: por unidad (costo op. ÷ 12)</p>
    </div>
    <button id="btn-print" class="bg-dark-surface border border-dark-border text-text-muted text-xs px-3 py-2 rounded-xl hover:text-text-main transition-all">🖨️ Imprimir</button>
  </header>

  <!-- Barra de contexto -->
  <div class="glass-panel rounded-2xl p-4 mb-4 grid grid-cols-2 lg:grid-cols-4 gap-3">
    <div>
      <p class="text-[0.6rem] text-text-muted uppercase tracking-wider">Total Op. Mes</p>
      <p class="font-bold text-purple-400" id="ctx-total-op">—</p>
    </div>
    <div>
      <p class="text-[0.6rem] text-text-muted uppercase tracking-wider">Pizzas / Mes</p>
      <p class="font-bold text-text-muted" id="ctx-pizzas">—</p>
    </div>
    <div>
      <p class="text-[0.6rem] text-text-muted uppercase tracking-wider">Costo Op. / Pizza</p>
      <p class="font-bold text-purple-400" id="ctx-costo-op">—</p>
    </div>
    <div>
      <p class="text-[0.6rem] text-text-muted uppercase tracking-wider">Última actualización</p>
      <p class="font-bold text-text-muted text-xs" id="ctx-updated">—</p>
    </div>
  </div>

  <!-- Tabla de precios -->
  <div class="glass-panel rounded-2xl overflow-hidden mb-4">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-text-muted text-[0.65rem] uppercase tracking-wider border-b border-dark-border/50">
            <th class="text-left p-3">Pizza</th>
            <th class="text-right p-3">Ingredientes</th>
            <th class="text-right p-3">+ Op/pizza</th>
            <th class="text-right p-3">= Costo Real</th>
            <th class="text-right p-3">Margen %</th>
            <th class="text-right p-3 text-orange-400">Precio Efectivo</th>
            <th class="p-3"></th>
          </tr>
        </thead>
        <tbody id="tbody-precios"></tbody>
      </table>
    </div>
  </div>

  <button id="btn-add-precio" class="glass-panel rounded-2xl px-4 py-3 text-sm text-text-muted hover:text-text-main hover:border-orange-500/50 transition-all w-full">+ Agregar producto a la lista</button>

</Layout>

<script>
  import { insforge } from '../lib/insforge';
  import { calcCostoOperativoPorPizza, calcCostoReceta, calcCostoRealTotal, calcPrecioEfectivo, markupToMargen, margenToMarkup, calcUnidadesReceta } from '../utils/pricing';

  const db = insforge.database;
  const fmt = (n: number) => '$' + Math.round(n).toLocaleString('es-AR');
  let costoOpPorPizza = 0;

  const CATEGORIAS = ['Pizzas', 'Calzones', 'Empanadas', 'Hamburguesas', 'Lomos', 'Otros'] as const;

  async function init() {
    const [{ data: fijos }, { data: variables }, { data: config }] = await Promise.all([
      db.from('costos_fijos').select('monto').eq('activo', true),
      db.from('costos_variables').select('monto_referencia'),
      db.from('config_negocio').select('pizzas_objetivo_mes').limit(1),
    ]);

    const totalOp = [
      ...(fijos ?? []).map((c: any) => c.monto),
      ...(variables ?? []).map((c: any) => c.monto_referencia),
    ].reduce((a: number, b: number) => a + b, 0);

    const pizzasMes = config?.[0]?.pizzas_objetivo_mes ?? 800;
    costoOpPorPizza = calcCostoOperativoPorPizza(totalOp, pizzasMes);

    document.getElementById('ctx-total-op')!.textContent = fmt(totalOp);
    document.getElementById('ctx-pizzas')!.textContent = String(pizzasMes);
    document.getElementById('ctx-costo-op')!.textContent = fmt(costoOpPorPizza);
    document.getElementById('ctx-updated')!.textContent = new Date().toLocaleTimeString('es-AR');

    await renderTabla();
  }

  async function renderTabla() {
    const { data: precios } = await db
      .from('precios_venta')
      .select('*, recetas(precio_prepizza, precio_salsa, receta_ingredientes(cantidad_kg, merma_factor, ingredientes(precio_kg)))')
      .order('nombre', { ascending: true });

    const porCategoria = new Map<string, any[]>();
    for (const cat of CATEGORIAS) porCategoria.set(cat, []);

    for (const item of (precios ?? [])) {
      const cat = CATEGORIAS.includes(item.subcategoria) ? item.subcategoria : 'Otros';
      const receta = item.recetas;
      let costoIng = 0;
      if (receta) {
        const ings = (receta.receta_ingredientes ?? []).map((i: any) => ({
          precio_kg: i.ingredientes?.precio_kg ?? 0,
          cantidad_kg: i.cantidad_kg,
          merma_factor: i.merma_factor,
        }));
        const costoReceta = calcCostoReceta(ings, receta.precio_prepizza, receta.precio_salsa);
        if (cat === 'Empanadas') {
          const unidades = calcUnidadesReceta(ings);
          costoIng = unidades > 0 ? costoReceta / unidades : costoReceta;
        } else {
          costoIng = costoReceta;
        }
      }
      const costoOpUnit = cat === 'Empanadas' ? costoOpPorPizza / 12 : costoOpPorPizza;
      const costoReal = calcCostoRealTotal(costoIng, costoOpUnit);
      const precioEfectivo = calcPrecioEfectivo(costoReal, item.markup);
      porCategoria.get(cat)!.push({ item, costoIng, costoOpUnit, costoReal, precioEfectivo });
    }

    let html = '';
    for (const cat of CATEGORIAS) {
      const filas = porCategoria.get(cat)!;
      const markups = [...new Set(filas.map(r => Number(r.item.markup)))];
      const margenDisplay = filas.length > 0 && markups.length === 1 ? String(markupToMargen(markups[0])) : '';
      const margenPlaceholder = filas.length === 0 ? '—' : markups.length > 1 ? 'Mixto' : '';

      html += `
        <tr class="bg-dark-surface/60 border-t-2 border-orange-500/30">
          <td colspan="4" class="px-3 py-2">
            <span class="text-orange-400 text-[0.65rem] font-bold uppercase tracking-widest">${cat}</span>
            <span class="text-text-muted text-[0.6rem] ml-2">${filas.length} producto${filas.length !== 1 ? 's' : ''}</span>
          </td>
          <td class="px-3 py-2">
            <div class="flex items-center justify-end gap-1">
              <input type="number" step="0.1" min="1" max="99"
                value="${margenDisplay}" placeholder="${margenPlaceholder}"
                ${filas.length === 0 ? 'disabled' : ''}
                class="w-20 bg-dark-bg border border-orange-500/40 rounded-lg px-2 py-1 text-right text-orange-400 text-sm focus:ring-1 focus:ring-orange-500/50 outline-none disabled:opacity-30 grupo-margen-input"
                data-grupo="${cat}">
              <span class="text-text-muted text-xs">%</span>
            </div>
          </td>
          <td class="px-3 py-2 text-right" colspan="2">
            ${filas.length > 0 ? `
            <button class="text-xs bg-orange-500/20 hover:bg-orange-500/40 text-orange-400 px-3 py-1 rounded-lg transition-all font-medium btn-apply-grupo" data-grupo="${cat}">
              Aplicar al grupo
            </button>` : ''}
          </td>
        </tr>
      `;

      for (const { item, costoIng, costoOpUnit, costoReal, precioEfectivo } of filas) {
        html += `
          <tr class="border-b border-dark-border/20 hover:bg-dark-surface/20 item-row" data-costo-real="${costoReal}" data-id="${item.id}" data-grupo="${cat}">
            <td class="p-3 pl-5 text-text-main">${item.nombre}</td>
            <td class="p-3 text-right text-emerald-400">${fmt(costoIng)}</td>
            <td class="p-3 text-right text-purple-400">${fmt(costoOpUnit)}</td>
            <td class="p-3 text-right text-text-muted">${fmt(costoReal)}</td>
            <td class="p-3 text-right">
              <div class="flex items-center justify-end gap-1">
                <input type="number" step="0.1" min="1" max="99" value="${markupToMargen(item.markup)}" data-id="${item.id}"
                  class="w-20 bg-dark-bg border border-dark-border rounded-lg px-2 py-1 text-right text-accent-amber text-sm focus:ring-1 focus:ring-accent-amber/50 outline-none markup-input">
                <span class="text-text-muted text-xs">%</span>
              </div>
            </td>
            <td class="p-3 text-right font-bold text-white text-base precio-efectivo">${fmt(precioEfectivo)}</td>
            <td class="p-3">
              <button data-id="${item.id}" class="text-red-400 text-xs hover:text-red-300 btn-del-precio">✕</button>
            </td>
          </tr>
        `;
      }
    }

    document.getElementById('tbody-precios')!.innerHTML = html;

    // Margen individual
    document.querySelectorAll('.markup-input').forEach(inp => {
      inp.addEventListener('change', async (e) => {
        const el = e.target as HTMLInputElement;
        const margen = parseFloat(el.value);
        const newMarkup = margenToMarkup(margen);
        await db.from('precios_venta').update({ markup: newMarkup }).eq('id', el.dataset.id!);
        const row = el.closest('tr') as HTMLElement;
        row.querySelector('.precio-efectivo')!.textContent = fmt(calcPrecioEfectivo(parseFloat(row.dataset.costoReal!), newMarkup));
        syncGrupoInput(row.dataset.grupo!);
      });
    });

    // Aplicar margen al grupo completo
    document.querySelectorAll('.btn-apply-grupo').forEach(btn => {
      btn.addEventListener('click', async () => {
        const cat = (btn as HTMLElement).dataset.grupo!;
        const grupoInput = document.querySelector<HTMLInputElement>(`.grupo-margen-input[data-grupo="${cat}"]`)!;
        const margen = parseFloat(grupoInput.value);
        if (isNaN(margen) || margen <= 0 || margen >= 100) return;
        const newMarkup = margenToMarkup(margen);
        const itemRows = document.querySelectorAll<HTMLElement>(`.item-row[data-grupo="${cat}"]`);
        const ids = Array.from(itemRows).map(r => r.dataset.id!);
        await db.from('precios_venta').update({ markup: newMarkup }).in('id', ids);
        itemRows.forEach(row => {
          row.querySelector('.precio-efectivo')!.textContent = fmt(calcPrecioEfectivo(parseFloat(row.dataset.costoReal!), newMarkup));
          (row.querySelector('.markup-input') as HTMLInputElement).value = String(margen);
        });
      });
    });

    // Borrar producto
    document.querySelectorAll('.btn-del-precio').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const id = (e.target as HTMLElement).dataset.id!;
        await db.from('precios_venta').delete().eq('id', id);
        renderTabla();
      });
    });
  }

  function syncGrupoInput(cat: string) {
    const inputs = Array.from(document.querySelectorAll<HTMLInputElement>(`.item-row[data-grupo="${cat}"] .markup-input`));
    const vals = inputs.map(i => parseFloat(i.value));
    const grupoInput = document.querySelector<HTMLInputElement>(`.grupo-margen-input[data-grupo="${cat}"]`);
    if (!grupoInput) return;
    const allEqual = vals.every(v => v === vals[0]);
    grupoInput.value = allEqual ? String(vals[0]) : '';
    grupoInput.placeholder = allEqual ? '' : 'Mixto';
  }

  document.getElementById('btn-add-precio')!.addEventListener('click', async () => {
    const nombre = prompt('Nombre del producto:');
    if (!nombre?.trim()) return;
    const catsStr = CATEGORIAS.map((c, i) => `${i + 1}. ${c}`).join('\n');
    const catInput = prompt(`Categoría:\n${catsStr}`);
    if (catInput === null) return;
    const catIdx = parseInt(catInput) - 1;
    const subcategoria = (catIdx >= 0 && catIdx < CATEGORIAS.length) ? CATEGORIAS[catIdx] : 'Otros';
    const { data: recetas } = await db.from('recetas').select('id, nombre').order('nombre', { ascending: true });
    const lista = (recetas ?? []).map((r: any, i: number) => `${i + 1}. ${r.nombre}`).join('\n');
    const idx = parseInt(prompt(`¿A qué receta corresponde? (0 para ninguna)\n${lista}`) ?? '0') - 1;
    const receta_id = idx >= 0 ? (recetas ?? [])[idx]?.id ?? null : null;
    await db.from('precios_venta').insert([{ nombre: nombre.trim(), subcategoria, receta_id, markup: 1.6 }]);
    renderTabla();
  });

  document.getElementById('btn-print')!.addEventListener('click', () => window.print());

  init();
</script>
