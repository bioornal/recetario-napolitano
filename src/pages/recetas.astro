---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---
<Layout title="Recetas">
  <header class="py-6 mb-4 border-b border-dark-border/50">
    <h1 class="font-['Outfit'] text-2xl font-bold text-accent-gold">📋 Recetas & Costos</h1>
    <p class="text-xs text-text-muted mt-1">Costos de producción por pizza — editá directamente en la tabla</p>
  </header>

  <!-- Lista de recetas -->
  <div class="flex items-center justify-between mb-4">
    <select id="select-receta" class="bg-dark-surface border border-dark-border text-text-main py-2 px-3 rounded-xl text-sm focus:ring-2 focus:ring-accent-amber/50 outline-none">
      <option value="">Cargando recetas...</option>
    </select>
    <div class="flex gap-2">
      <button id="btn-nueva-receta" class="bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-semibold px-3 py-2 rounded-xl transition-all">+ Nueva receta</button>
      <button id="btn-eliminar-receta" class="bg-red-900/50 hover:bg-red-800 text-red-400 text-xs font-semibold px-3 py-2 rounded-xl transition-all hidden">Eliminar receta</button>
    </div>
  </div>

  <!-- Editor de receta -->
  <div id="editor-receta" class="hidden">
    <div class="glass-panel rounded-2xl p-5 mb-4">
      <div class="flex gap-4 mb-4 flex-wrap">
        <div class="flex-1 min-w-40">
          <label class="text-[0.65rem] text-text-muted uppercase tracking-wider">Nombre de la pizza</label>
          <input id="inp-nombre" type="text" class="mt-1 w-full bg-dark-surface border border-dark-border rounded-xl px-3 py-2 text-text-main text-sm focus:ring-2 focus:ring-accent-amber/50 outline-none">
        </div>
        <div class="w-32">
          <label class="text-[0.65rem] text-text-muted uppercase tracking-wider">Prepizza ($)</label>
          <input id="inp-prepizza" type="number" class="mt-1 w-full bg-dark-surface border border-dark-border rounded-xl px-3 py-2 text-text-main text-sm focus:ring-2 focus:ring-accent-amber/50 outline-none">
        </div>
        <div class="w-32">
          <label class="text-[0.65rem] text-text-muted uppercase tracking-wider">Salsa ($)</label>
          <input id="inp-salsa" type="number" class="mt-1 w-full bg-dark-surface border border-dark-border rounded-xl px-3 py-2 text-text-main text-sm focus:ring-2 focus:ring-accent-amber/50 outline-none">
        </div>
      </div>
    </div>

    <!-- Tabla de ingredientes -->
    <div class="glass-panel rounded-2xl overflow-hidden mb-4">
      <div class="flex items-center justify-between p-4 border-b border-dark-border/50">
        <h2 class="text-xs uppercase tracking-wider text-accent-amber font-bold">Ingredientes</h2>
        <button id="btn-add-ing" class="bg-emerald-600/20 text-emerald-400 text-xs font-semibold px-3 py-1.5 rounded-lg hover:bg-emerald-600/40 transition-all">+ Agregar</button>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-text-muted text-[0.65rem] uppercase tracking-wider border-b border-dark-border/50">
              <th class="text-left p-3">Ingrediente</th>
              <th class="text-right p-3">$/kg</th>
              <th class="text-right p-3" title="Cantidad Neta (Lo que pide la receta)">Cant. Neta (kg)</th>
              <th class="text-right p-3 text-accent-amber/70" title="Múltiplo de Rendimiento">MR</th>
              <th class="text-right p-3" title="Cantidad Bruta a comprar">A Comprar (kg)</th>
              <th class="text-right p-3">Costo</th>
              <th class="p-3"></th>
            </tr>
          </thead>
          <tbody id="tabla-ingredientes"></tbody>
        </table>
      </div>
      <div class="flex justify-between items-center p-4 border-t border-dark-border/50 bg-dark-surface/50">
        <span class="text-xs text-text-muted uppercase tracking-wider">Costo total receta</span>
        <span class="text-xl font-bold text-emerald-400" id="costo-total">$0</span>
      </div>
      <div id="rendimiento-panel" class="hidden border-t border-dark-border/30 p-3 bg-dark-surface/20 flex items-center justify-between gap-4 flex-wrap">
        <div class="flex items-center gap-2 text-xs text-text-muted">
          <select id="rend-tipo-calc" class="bg-dark-bg border border-dark-border text-xs rounded-lg px-2 py-1 text-text-main outline-none focus:ring-1 focus:ring-accent-amber/50">
            <option value="directo">Unidad directa (Pizzas/Hamburguesas)</option>
            <option value="peso">Por peso (Empanadas)</option>
          </select>
          
          <div id="rend-calc-peso" class="flex items-center gap-2 pl-2 border-l border-dark-border/50 hidden">
            <span>Total masa <span class="text-accent-amber font-mono font-semibold" id="rend-mr-g">—</span> g</span>
            <span>÷</span>
            <input id="inp-gramos-unidad" type="number" value="65" min="1" step="1"
              class="w-14 bg-dark-bg border border-dark-border rounded-lg px-2 py-1 text-xs text-right text-accent-amber outline-none focus:ring-1 focus:ring-accent-amber/50">
            <span>g/un. =</span>
            <span class="text-text-main font-semibold" id="rend-unidades">—</span>
            <span>unidades</span>
          </div>

          <div id="rend-calc-directo" class="flex items-center gap-2 pl-2 border-l border-dark-border/50">
            <span>Rinde:</span>
            <input id="inp-unidades-directo" type="number" value="1" min="1" step="1"
              class="w-14 bg-dark-bg border border-dark-border rounded-lg px-2 py-1 text-xs text-right text-accent-amber outline-none focus:ring-1 focus:ring-accent-amber/50">
            <span>unidades</span>
          </div>
        </div>
        <div class="flex items-center gap-2 text-xs">
          <span class="text-text-muted">Costo / unidad</span>
          <span class="font-bold text-emerald-400 text-base" id="rend-costo">—</span>
        </div>
      </div>
    </div>

    <button id="btn-guardar" class="w-full bg-accent-amber text-dark-bg font-bold py-3 rounded-xl hover:bg-accent-gold transition-all">Guardar receta</button>
  </div>


</Layout>

<script>
  import { insforge } from '../lib/insforge';
  import { calcCostoReceta } from '../utils/pricing';
  import { fmt, TIPOS, showDbError, escapeHtml } from '../utils/fmt';

  const db = insforge.database;

  let ingredientesGlobales: any[] = [];
  let recetaActual: any = null;
  let ingredientesReceta: any[] = [];

  async function init() {
    ingredientesGlobales = (await db.from('ingredientes').select('*').order('nombre', { ascending: true })).data ?? [];
    await cargarSelectRecetas();
  }

  async function cargarSelectRecetas() {
    const { data } = await db.from('recetas').select('id, nombre').order('nombre', { ascending: true });
    const sel = document.getElementById('select-receta') as HTMLSelectElement;
    sel.innerHTML = '<option value="">— Seleccioná una receta —</option>';
    (data ?? []).forEach((r: any) => {
      sel.innerHTML += `<option value="${r.id}">${r.nombre}</option>`;
    });
  }

  document.getElementById('select-receta')!.addEventListener('change', async (e) => {
    const id = (e.target as HTMLSelectElement).value;
    if (!id) { document.getElementById('editor-receta')!.classList.add('hidden'); return; }
    await cargarReceta(id);
  });

  async function cargarReceta(id: string) {
    const [{ data: receta }, { data: ings }] = await Promise.all([
      db.from('recetas').select('*').eq('id', id).single(),
      db.from('receta_ingredientes').select('*, ingredientes(nombre, precio_kg)').eq('receta_id', id),
    ]);
    recetaActual = receta;
    ingredientesReceta = ings ?? [];
    (document.getElementById('inp-nombre') as HTMLInputElement).value = receta.nombre;
    (document.getElementById('inp-prepizza') as HTMLInputElement).value = receta.precio_prepizza;
    (document.getElementById('inp-salsa') as HTMLInputElement).value = receta.precio_salsa;
    (document.getElementById('rend-tipo-calc') as HTMLSelectElement).value = receta.rend_tipo || 'directo';
    if ((receta.rend_tipo || 'directo') === 'peso') {
      (document.getElementById('inp-gramos-unidad') as HTMLInputElement).value = receta.rend_valor || 65;
    } else {
      (document.getElementById('inp-unidades-directo') as HTMLInputElement).value = receta.rend_valor || 1;
    }
    document.getElementById('editor-receta')!.classList.remove('hidden');
    document.getElementById('btn-eliminar-receta')!.classList.remove('hidden');
    renderTablaIngredientesReceta();
  }

  function renderTablaIngredientesReceta() {
    const tbody = document.getElementById('tabla-ingredientes')!;
    const prepizza = parseFloat((document.getElementById('inp-prepizza') as HTMLInputElement).value) || 0;
    const salsa = parseFloat((document.getElementById('inp-salsa') as HTMLInputElement).value) || 0;

    // Enriquecer con tipo desde ingredientesGlobales y ordenar
    const enriquecidos = ingredientesReceta.map((ing: any, i: number) => {
      const global = ingredientesGlobales.find((g: any) => g.id === (ing.ingrediente_id ?? ing.ingredientes?.id));
      return { ...ing, _tipo: global?.tipo ?? 'Varios', _idx: i };
    }).sort((a: any, b: any) => {
      const ti = TIPOS.indexOf(a._tipo), tj = TIPOS.indexOf(b._tipo);
      if (ti !== tj) return ti - tj;
      return (a.ingredientes?.nombre ?? '').localeCompare(b.ingredientes?.nombre ?? '');
    });

    let html = '';
    let tipoActual = '';
    for (const ing of enriquecidos) {
      if (ing._tipo !== tipoActual) {
        tipoActual = ing._tipo;
        html += `<tr class="bg-dark-surface/40"><td colspan="6" class="px-3 py-1.5 text-[0.6rem] font-bold uppercase tracking-widest text-accent-amber/70">${tipoActual}</td></tr>`;
      }
      const i = ing._idx;
      const globalIng = ingredientesGlobales.find((g: any) => g.id === (ing.ingrediente_id ?? ing.ingredientes?.id));
      const mr = globalIng?.multiplo_rendimiento ?? 1;
      const cantNeta = ing.cantidad_kg || 0;
      const cantBruta = cantNeta * mr;
      const costoLine = (globalIng?.precio_kg ?? 0) * cantBruta;
      
      html += `
        <tr class="border-b border-dark-border/20 hover:bg-dark-surface/30">
          <td class="p-3 text-text-main">${escapeHtml(globalIng?.nombre ?? '?')}</td>
          <td class="p-3 text-right text-accent-amber">${fmt(globalIng?.precio_kg ?? 0)}</td>
          <td class="p-3 text-right">
            <input type="number" step="0.001" value="${cantNeta}" data-idx="${i}" data-field="cantidad_kg"
              class="w-24 bg-dark-bg border border-dark-border rounded-lg px-2 py-1 text-right text-text-main text-xs focus:ring-1 focus:ring-accent-amber/50 outline-none ing-input">
          </td>
          <td class="p-3 text-right text-emerald-400 font-mono">${mr.toFixed(2)}</td>
          <td class="p-3 text-right text-text-muted font-mono">${cantBruta.toFixed(3)}</td>
          <td class="p-3 text-right text-text-main font-medium">${fmt(costoLine)}</td>
          <td class="p-3">
            <button data-idx="${i}" class="text-red-400 text-xs hover:text-red-300 btn-del-ing">✕</button>
          </td>
        </tr>`;
    }
    
    // Fila de totales
    const totalCantNeta = enriquecidos.reduce((a: number, i: any) => a + (i.cantidad_kg || 0), 0);
    const totalCantBruta = enriquecidos.reduce((a: number, i: any) => {
      const g = ingredientesGlobales.find((x: any) => x.id === (i.ingrediente_id ?? i.ingredientes?.id));
      return a + (i.cantidad_kg || 0) * (g?.multiplo_rendimiento ?? 1);
    }, 0);
    const totalCosto = enriquecidos.reduce((a: number, i: any) => {
      const g = ingredientesGlobales.find((x: any) => x.id === (i.ingrediente_id ?? i.ingredientes?.id));
      return a + (g?.precio_kg ?? 0) * (i.cantidad_kg || 0) * (g?.multiplo_rendimiento ?? 1);
    }, 0);
    
    html += `
      <tr class="border-t-2 border-dark-border/60 bg-dark-surface/40 font-semibold text-xs">
        <td class="p-3 text-text-muted uppercase tracking-wider" colspan="2">Totales</td>
        <td class="p-3 text-right text-text-main font-mono">${totalCantNeta.toFixed(3)}</td>
        <td class="p-3 text-right text-emerald-400 font-mono"></td>
        <td class="p-3 text-right text-text-muted font-mono">${totalCantBruta.toFixed(3)}</td>
        <td class="p-3 text-right text-text-main">${fmt(totalCosto + prepizza + salsa)}</td>
        <td class="p-3"></td>
      </tr>`;
    tbody.innerHTML = html;

    document.querySelectorAll('.ing-input').forEach(inp => {
      inp.addEventListener('change', async (e) => {
        const el = e.target as HTMLInputElement;
        const idx = parseInt(el.dataset.idx!);
        const field = el.dataset.field!;
        const newVal = parseFloat(el.value);
        ingredientesReceta[idx][field] = newVal;
        if (recetaActual?.id && ingredientesReceta[idx].ingrediente_id) {
          await db.from('receta_ingredientes')
            .update({ [field]: newVal })
            .eq('receta_id', recetaActual.id)
            .eq('ingrediente_id', ingredientesReceta[idx].ingrediente_id);
        }
        renderTablaIngredientesReceta();
      });
    });

    document.querySelectorAll('.btn-del-ing').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt((btn as HTMLElement).dataset.idx!);
        ingredientesReceta.splice(idx, 1);
        renderTablaIngredientesReceta();
      });
    });

    const costo = calcCostoReceta(
      ingredientesReceta.map((i: any) => {
        const g = ingredientesGlobales.find((x: any) => x.id === (i.ingrediente_id ?? i.ingredientes?.id));
        return { precio_kg: g?.precio_kg ?? 0, cantidad_kg: i.cantidad_kg, multiplo_rendimiento: g?.multiplo_rendimiento ?? 1 };
      }),
      prepizza, salsa
    );
    document.getElementById('costo-total')!.textContent = fmt(costo);

    // Rendimiento
    const rendPanel = document.getElementById('rendimiento-panel')!;
    if (totalCantNeta > 0 || (document.getElementById('rend-tipo-calc') as HTMLSelectElement).value === 'directo') {
      rendPanel.classList.remove('hidden');
      const tipoCalc = (document.getElementById('rend-tipo-calc') as HTMLSelectElement).value;
      
      document.getElementById('rend-calc-peso')!.classList.toggle('hidden', tipoCalc !== 'peso');
      document.getElementById('rend-calc-directo')!.classList.toggle('hidden', tipoCalc !== 'directo');

      let unidades = 1;
      
      if (tipoCalc === 'peso') {
        const gramosInput = document.getElementById('inp-gramos-unidad') as HTMLInputElement;
        const gramosPorUnidad = parseFloat(gramosInput?.value) || 65;
        unidades = totalCantNeta > 0 ? Math.floor((totalCantNeta * 1000) / gramosPorUnidad) : 0;
        
        const docenas = Math.floor(unidades / 12);
        const resto = unidades % 12;
        const docenasStr = docenas > 0 ? `${docenas} doc.${resto > 0 ? ` y ${resto}` : ''}` : `${resto} un.`;
        
        document.getElementById('rend-mr-g')!.textContent = (totalCantNeta * 1000).toFixed(0);
        document.getElementById('rend-unidades')!.textContent = `${unidades} (${docenasStr})`;
      } else {
        const directInput = document.getElementById('inp-unidades-directo') as HTMLInputElement;
        unidades = parseFloat(directInput?.value) || 1;
      }
      
      if (unidades > 0) {
        document.getElementById('rend-costo')!.textContent = fmt(costo / unidades);
      } else {
        document.getElementById('rend-costo')!.textContent = '—';
      }
    } else {
      rendPanel.classList.add('hidden');
    }
  }

  document.getElementById('inp-prepizza')!.addEventListener('input', renderTablaIngredientesReceta);
  document.getElementById('inp-salsa')!.addEventListener('input', renderTablaIngredientesReceta);
  document.getElementById('rend-tipo-calc')!.addEventListener('change', renderTablaIngredientesReceta);
  document.getElementById('inp-gramos-unidad')!.addEventListener('input', renderTablaIngredientesReceta);
  document.getElementById('inp-unidades-directo')!.addEventListener('input', renderTablaIngredientesReceta);

  document.getElementById('btn-add-ing')!.addEventListener('click', () => {
    // Mostrar ingredientes agrupados por tipo en el prompt
    const grupos = TIPOS.map(tipo => {
      const ings = ingredientesGlobales.filter((i: any) => (i.tipo ?? 'Varios') === tipo);
      if (ings.length === 0) return '';
      return `${tipo}:\n` + ings.map((i: any) => `  ${i.nombre}`).join('\n');
    }).filter(Boolean).join('\n\n');
    const nombre = prompt(`Agregar ingrediente:\n\n${grupos}`);
    const ing = ingredientesGlobales.find((i: any) => i.nombre.toLowerCase() === nombre?.toLowerCase().trim());
    if (!ing) return alert('Ingrediente no encontrado. Verificá el nombre o agregalo en la tabla de ingredientes.');
    ingredientesReceta.push({ ingrediente_id: ing.id, cantidad_kg: 0.1, merma_factor: 1.0, ingredientes: ing });
    renderTablaIngredientesReceta();
  });

  document.getElementById('btn-nueva-receta')!.addEventListener('click', () => {
    recetaActual = null;
    ingredientesReceta = [];
    (document.getElementById('inp-nombre') as HTMLInputElement).value = '';
    (document.getElementById('inp-prepizza') as HTMLInputElement).value = '485';
    (document.getElementById('inp-salsa') as HTMLInputElement).value = '236';
    (document.getElementById('rend-tipo-calc') as HTMLSelectElement).value = 'directo';
    (document.getElementById('inp-unidades-directo') as HTMLInputElement).value = '1';
    (document.getElementById('inp-gramos-unidad') as HTMLInputElement).value = '65';
    (document.getElementById('select-receta') as HTMLSelectElement).value = '';
    document.getElementById('editor-receta')!.classList.remove('hidden');
    document.getElementById('btn-eliminar-receta')!.classList.add('hidden');
    renderTablaIngredientesReceta();
  });

  document.getElementById('btn-guardar')!.addEventListener('click', async () => {
    const nombre = (document.getElementById('inp-nombre') as HTMLInputElement).value.trim();
    const precio_prepizza = parseFloat((document.getElementById('inp-prepizza') as HTMLInputElement).value);
    const precio_salsa = parseFloat((document.getElementById('inp-salsa') as HTMLInputElement).value);
    const rend_tipo = (document.getElementById('rend-tipo-calc') as HTMLSelectElement).value;
    const rend_valor = parseFloat((document.getElementById(rend_tipo === 'peso' ? 'inp-gramos-unidad' : 'inp-unidades-directo') as HTMLInputElement).value) || 1;
    if (!nombre) return alert('Nombre requerido');

    try {
      if (recetaActual) {
        await db.from('recetas').update({ nombre, precio_prepizza, precio_salsa, rend_tipo, rend_valor }).eq('id', recetaActual.id);
        const snapshot = ingredientesReceta.map((i: any) => ({
          receta_id: recetaActual.id, ingrediente_id: i.ingrediente_id,
          cantidad_kg: i.cantidad_kg, merma_factor: i.merma_factor ?? 1,
        }));
        await db.from('receta_ingredientes').delete().eq('receta_id', recetaActual.id);
        if (snapshot.length > 0) {
          const { error } = await db.from('receta_ingredientes').insert(snapshot);
          if (error) {
            await db.from('receta_ingredientes').insert(snapshot.map(r => ({ ...r })));
            throw error;
          }
        }
      } else {
        const { data } = await db.from('recetas').insert([{ nombre, precio_prepizza, precio_salsa, rend_tipo, rend_valor }]).select('id').single();
        recetaActual = data;
        if (ingredientesReceta.length > 0) {
          await db.from('receta_ingredientes').insert(ingredientesReceta.map((i: any) => ({
            receta_id: recetaActual.id, ingrediente_id: i.ingrediente_id,
            cantidad_kg: i.cantidad_kg, merma_factor: i.merma_factor ?? 1,
          })));
        }
      }
      await cargarSelectRecetas();
      alert('Receta guardada ✓');
    } catch {
      alert('Error al guardar. Recargá la página para verificar el estado.');
    }
  });

  document.getElementById('btn-eliminar-receta')!.addEventListener('click', async () => {
    if (!recetaActual || !confirm(`¿Eliminar "${recetaActual.nombre}"?`)) return;
    await db.from('recetas').delete().eq('id', recetaActual.id);
    recetaActual = null;
    ingredientesReceta = [];
    document.getElementById('editor-receta')!.classList.add('hidden');
    document.getElementById('btn-eliminar-receta')!.classList.add('hidden');
    await cargarSelectRecetas();
  });



  init().catch(showDbError);
</script>
