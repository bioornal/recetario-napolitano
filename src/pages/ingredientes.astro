---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
---
<Layout title="Ingredientes">
  <header class="py-6 mb-4 border-b border-dark-border/50">
    <h1 class="font-['Outfit'] text-2xl font-bold text-accent-gold">🍅 Ingredientes</h1>
    <p class="text-xs text-text-muted mt-1">Gestión de precios y múltiplos de rendimiento (MR)</p>
  </header>

  <div class="glass-panel rounded-2xl overflow-hidden mt-6">
    <div class="flex items-center justify-between p-4 border-b border-dark-border/50">
      <div>
        <h2 class="text-xs uppercase tracking-wider text-accent-amber font-bold">Precios de Ingredientes</h2>
        <p class="text-[0.65rem] text-text-muted mt-0.5">Editá el precio por kg o MR — actualiza todos los costos</p>
      </div>
      <button id="btn-add-ingrediente-global" class="bg-emerald-600/20 text-emerald-400 text-xs font-semibold px-3 py-1.5 rounded-lg hover:bg-emerald-600/40 transition-all">+ Nuevo ingrediente</button>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-text-muted text-[0.65rem] uppercase tracking-wider border-b border-dark-border/50">
            <th class="text-left p-3">Ingrediente</th>
            <th class="text-right p-3">$/kg</th>
            <th class="text-right p-3" title="Múltiplo de Rendimiento (Cost Factor)">MR</th>
            <th class="text-right p-3">Unidad</th>
            <th class="p-3"></th>
          </tr>
        </thead>
        <tbody id="tabla-ingredientes-precios">
          <tr><td colspan="5" class="p-6 text-center text-text-muted text-sm">Cargando ingredientes...</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</Layout>

<script>
  import { insforge } from '../lib/insforge';
  import { TIPOS, showDbError, escapeHtml } from '../utils/fmt';

  const db = insforge.database;

  let ingredientesGlobales: any[] = [];

  async function init() {
    ingredientesGlobales = (await db.from('ingredientes').select('*').order('nombre', { ascending: true })).data ?? [];
    await renderTablaIngredientesGlobales();
  }

  async function renderTablaIngredientesGlobales() {
    const tbody = document.getElementById('tabla-ingredientes-precios')!;

    const porTipo = new Map<string, any[]>();
    for (const t of TIPOS) porTipo.set(t, []);
    for (const ing of ingredientesGlobales) {
      const t = TIPOS.includes(ing.tipo) ? ing.tipo : 'Varios';
      porTipo.get(t)!.push(ing);
    }

    let html = '';
    for (const tipo of TIPOS) {
      const ings = porTipo.get(tipo)!;
      if (ings.length === 0) continue;
      html += `<tr class="bg-dark-surface/60 border-t-2 border-accent-amber/20">
        <td colspan="5" class="px-3 py-2 text-[0.6rem] font-bold uppercase tracking-widest text-accent-amber/80">${tipo}</td>
      </tr>`;
      html += ings.map((ing: any) => `
        <tr class="border-b border-dark-border/20 hover:bg-dark-surface/30">
          <td class="p-3 pl-5 text-text-main">${escapeHtml(ing.nombre)}</td>
          <td class="p-3 text-right">
            <input type="number" value="${escapeHtml(ing.precio_kg)}" data-id="${escapeHtml(ing.id)}" data-field="precio_kg"
              class="w-24 bg-dark-bg border border-dark-border rounded-lg px-2 py-1 text-right text-accent-amber text-sm focus:ring-1 focus:ring-accent-amber/50 outline-none global-ing-input">
          </td>
          <td class="p-3 text-right">
            <input type="number" step="0.01" value="${escapeHtml(ing.multiplo_rendimiento ?? 1)}" data-id="${escapeHtml(ing.id)}" data-field="multiplo_rendimiento"
              class="w-20 bg-dark-bg border border-dark-border rounded-lg px-2 py-1 text-right text-emerald-400 text-sm focus:ring-1 focus:ring-emerald-400/50 outline-none global-ing-input">
          </td>
          <td class="p-3 text-right text-text-muted text-xs">${escapeHtml(ing.unidad)}</td>
          <td class="p-3">
            <button data-id="${escapeHtml(ing.id)}" class="text-red-400 text-xs hover:text-red-300 btn-del-ing-global">✕</button>
          </td>
        </tr>
      `).join('');
    }
    tbody.innerHTML = html;

    document.querySelectorAll('.global-ing-input').forEach(inp => {
      inp.addEventListener('change', async (e) => {
        const el = e.target as HTMLInputElement;
        const field = el.dataset.field!;
        const val = parseFloat(el.value);
        
        const ing = ingredientesGlobales.find(i => i.id === el.dataset.id);
        if (ing) ing[field] = val;
        
        await db.from('ingredientes').update({ [field]: val, updated_at: new Date().toISOString() }).eq('id', el.dataset.id!);
      });
    });

    document.querySelectorAll('.btn-del-ing-global').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.id!;
        if (!confirm('¿Eliminar ingrediente? Se eliminará de todas las recetas.')) return;
        await db.from('ingredientes').delete().eq('id', id);
        ingredientesGlobales = ingredientesGlobales.filter((i: any) => i.id !== id);
        renderTablaIngredientesGlobales();
      });
    });
  }

  document.getElementById('btn-add-ingrediente-global')!.addEventListener('click', async () => {
    const nombre = prompt('Nombre del ingrediente:');
    if (!nombre?.trim()) return;
    const precio_kg = parseFloat(prompt('Precio por kg ($):') ?? '0');
    const unidad = prompt('Unidad (kg / unidad / litro):') ?? 'kg';
    const tiposStr = TIPOS.map((t, i) => `${i + 1}. ${t}`).join('\n');
    const tipoIdx = parseInt(prompt(`Tipo:\n${tiposStr}`) ?? '6') - 1;
    const tipo = (tipoIdx >= 0 && tipoIdx < TIPOS.length) ? TIPOS[tipoIdx] : 'Varios';
    const { data } = await db.from('ingredientes').insert([{ nombre: nombre.trim(), precio_kg, unidad, tipo }]).select('*').single();
    ingredientesGlobales.push(data);
    ingredientesGlobales.sort((a: any, b: any) => a.nombre.localeCompare(b.nombre));
    renderTablaIngredientesGlobales();
  });

  init().catch(showDbError);
</script>
